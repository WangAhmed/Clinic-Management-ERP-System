@model IEnumerable<Appointment.Models.s_Doctor>
@{
    ViewBag.Title = "Index";
    // Debugging: Log or output the current user type
    var userType = Session["UserType"] as string;
    System.Diagnostics.Debug.WriteLine($"Current UserType: {userType}");

    // Determine the layout based on the user type
    if (userType == "Doctor")
    {
        Layout = "~/Views/Shared/_Layout_doctor.cshtml";
    }
    else if (userType == "Patient")
    {
        Layout = "~/Views/Shared/_Layout_patient.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
}

<!-- Home Banner -->
<section class="section section-search">
    <div class="container-fluid">
        <div class="banner-wrapper">
            <div class="banner-header text-center">
                <h1>Search Doctor, Make an Appointment</h1>
                <p>Discover the best doctors, clinic & hospital.</p>
            </div>

            <div class="search-box">
                <form action="/Home/Search" method="get">
                    <div class="form-group search-Specialist">
                        <input name="SpecialistID" type="search" class="form-control" placeholder="Search Specialist">
                        <span class="form-text">Based on your Specialist</span>
                    </div>
                    <div class="form-group search-info">
                        <input name="DoctorName" type="search" class="form-control" placeholder="Search Doctors, Clinics, Hospitals, Diseases Etc">
                        <span class="form-text">Ex: Dental or Sugar Check up etc</span>
                    </div>
                    <button type="submit" class="btn btn-primary search-btn"><i class="fas fa-search"></i> <span>Search</span></button>
                </form>
            </div>


        </div>
    </div>
</section>
<!-- /Home Banner -->
