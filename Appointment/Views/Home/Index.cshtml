<!-- Popular Section -->
<section class="section section-doctor">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-4">
                <div class="section-header ">
                    <h2>Book Our Doctor</h2>
                    <p>We have Professional Doctor all over Cities</p>
                </div>
                <div class="about-content">
                    <p>At the core of our mission is the commitment to enhancing the healthcare experience for all stakeholders. We believe that efficient appointment management is crucial for the well-being of patients and the smooth operation of healthcare facilities. Our system strives to simplify the process, providing a seamless and user-friendly platform for patients to connect with their healthcare providers..</p>
                    <p>The system also serves as a platform for disseminating information on diseases, preventions, cures, medical news, and innovations in medical science.</p>
                    <a href="javascript:;">Read More..</a>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="doctor-slider slider">
                    use for each and get up 10 record Form model only



                    @foreach (var item in Model)
                    {
                        <!-- Doctor Widget -->
                        <div class="profile-widget">
                            <div class="doc-img">
                                <a href="@Url.Action("Detail", "Home", new { id = item.DoctorID })">
                                    <img class="img-fluid" alt="Doctor Image" src="~/@(!string.IsNullOrEmpty(item.image) ? Url.Content(item.image) : Url.Content("~/images/default-doctor.png"))">
                                </a>
                                <a href="javascript:void(0)" class="fav-btn">
                                    <i class="far fa-bookmark"></i>
                                </a>
                            </div>
                            <div class="pro-content">
                                <h3 class="title">
                                    <a href="@Url.Action("Detail", "Home", new { id = item.DoctorID })">
                                        @item.FirstName @item.LastName
                                    </a>
                                    <i class="fas fa-check-circle verified"></i>
                                </h3>
                                <p class="speciality">@item.s_Specialist.SpecialistName</p>
                                <div class="rating">
                                    <i class="fas fa-star filled"></i>
                                    <i class="fas fa-star filled"></i>
                                    <i class="fas fa-star filled"></i>
                                    <i class="fas fa-star filled"></i>
                                    <i class="fas fa-star filled"></i>
                                    <span class="d-inline-block average-rating">(17)</span>
                                </div>
                                <div class="row row-sm">
                                    <div class="col-6">
                                        <a href="@Url.Action("Detail", "Home", new { id = item.DoctorID })" class="btn view-btn">View Profile</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- /Doctor Widget -->
                    }



                </div>
            </div>
        </div>
    </div>
</section>
<!-- /Popular Section -->
