@model IEnumerable<Appointment.Models.s_DoctorSchedule>

@{
    ViewBag.Title = "Schedule Timings";
    Layout = "~/Views/Shared/_Layout_doctor.cshtml";
    var appointments = ViewBag.Appointments as List<Appointment.Models.AppointmentViewModel>;
    var userType = Session["UserType"] as string;
    System.Diagnostics.Debug.WriteLine($"Current UserType: {userType}");

    // Determine the layout based on the user type
    if (userType == "Doctor")
    {
        Layout = "~/Views/Shared/_Layout_doctor.cshtml";
    }
    else if (userType == "Patient")
    {
        Layout = "~/Views/Shared/_Layout_patient.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
}

<!-- Breadcrumb -->
<div class="breadcrumb-bar">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-12 col-12">
                <nav aria-label="breadcrumb" class="page-breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="\Home\Index">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Schedule Timings</li>
                    </ol>
                </nav>
                <h2 class="breadcrumb-title">Schedule Timings</h2>
            </div>
        </div>
    </div>
</div>
<!-- /Breadcrumb -->
<!-- Page Content -->
<div class="content">
    <div class="container-fluid">

        <div class="row">
            <div class="col-md-5 col-lg-4 col-xl-3 theiaStickySidebar">
                @Html.Partial("_DoctorSidebar")
            </div>

            <div class="col-md-7 col-lg-8 col-xl-9">
                <div class="content container-fluid">
                    <div class="page-header">
                        <div class="row align-items-center">
                            <div class="col">
                                <h3 class="page-title">Schedule Timings</h3>
                                <ul class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Doctor")">Dashboard</a></li>
                                    <li class="breadcrumb-item active">Schedule Timings</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-auto text-right float-right ml-auto">
                            <a href="@Url.Action("Create", "s_DoctorSchedule")" class="btn btn-outline-primary mr-2"><i class="fas fa-plus"></i> Add Timing</a>
                            <a href="@Url.Action("Create", "s_DoctorSchedule")" class="btn btn-primary"><i class="fas fa-plus"></i></a>
                        </div>
                        <div class="col-sm-12">
                            <div class="card card-table">
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-hover table-center mb-0 datatable">
                                            <thead>
                                                <tr>
                                                    <th>Doctor Image</th>
                                                    <th>@Html.DisplayNameFor(model => model.FirstOrDefault().AvailableDate)</th>
                                                    <th>@Html.DisplayNameFor(model => model.FirstOrDefault().StartTime)</th>
                                                    <th>@Html.DisplayNameFor(model => model.FirstOrDefault().EndTime)</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (Model.Any())
                                                {
                                                    foreach (var item in Model)
                                                    {
                                                        <tr>
                                                            <td>
                                                                @if (!string.IsNullOrEmpty(item.s_Doctor?.image))
                                                                {
                                                                    <img src="@Url.Content(item.s_Doctor.image)" alt="Doctor Image" style="width: 50px; height: 50px; object-fit: cover;">
                                                                }
                                                                else
                                                                {
                                                                    <img src="@Url.Content("~/images/default-doctor.png")" alt="Default Image" style="width: 50px; height: 50px; object-fit: cover;">
                                                                }
                                                            </td>
                                                            <td>@item.AvailableDate</td>
                                                            <td>@item.StartTime</td>
                                                            <td>@item.EndTime</td>
                                                            <td>
                                                                @Html.ActionLink("Edit", "Edit", new { id = item.SchID }) |
                                                                @Html.ActionLink("Delete", "Delete", new { id = item.SchID })
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                                else
                                                {
                                                    <tr>
                                                        <td colspan="5">No schedules available.</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- /Page Content -->
