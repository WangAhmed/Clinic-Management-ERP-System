@model Appointment.Models.s_LabTest

@{
    ViewBag.Title = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userType = Session["UserType"] as string;
    System.Diagnostics.Debug.WriteLine($"Current UserType: {userType}");

    // Determine the layout based on the user type
    if (userType == "Doctor")
    {
        Layout = "~/Views/Shared/_Layout_doctor.cshtml";
    }
    else if (userType == "Patient")
    {
        Layout = "~/Views/Shared/_Layout_patient.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
}

<!-- Breadcrumb -->
<div class="breadcrumb-bar">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-12 col-12">
                <nav aria-label="breadcrumb" class="page-breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "s_LabTest")">Lab Tests</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Delete Lab Test</li>
                    </ol>
                </nav>
                <h2 class="breadcrumb-title">Delete Lab Test</h2>
            </div>
        </div>
    </div>
</div>
<!-- /Breadcrumb -->
<!-- Page Content -->
<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-5 col-lg-4 col-xl-3 theiaStickySidebar">
                @Html.Partial("_DoctorSidebar")
            </div>

            <div class="col-md-7 col-lg-8 col-xl-9">
                <div class="content container-fluid">
                    <div class="page-header">
                        <div class="row align-items-center">
                            <div class="col">
                                <h3 class="page-title">Delete Lab Test</h3>
                                <ul class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "s_LabTest")">Lab Tests</a></li>
                                    <li class="breadcrumb-item active">Delete Lab Test</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="card card-table">
                        <div class="card-body">
                            <h4>Are you sure you want to delete this Lab Test?</h4>
                            <div class="form-group">
                                <label>Test Name:</label>
                                <p>@Model.TestName</p>
                            </div>
                            <div class="form-group">
                                <label>Patient:</label>
                                <p>@Model.s_Patient.FirstName</p>
                            </div>
                            <div class="form-group">
                                <label>Test Date:</label>
                                <p>@Model.TestDate</p>
                            </div>
                            <div class="form-group">
                                <label>Cost:</label>
                                <p>@Model.Cost.ToString("C")</p>
                            </div>
                            <div class="form-group">
                                <label>Price:</label>
                                <p>@Model.Price.ToString("C")</p>
                            </div>

                            @using (Html.BeginForm("Delete", "s_LabTest", FormMethod.Post, new { @class = "form-horizontal" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.HiddenFor(model => model.LabTestID)
                                <input type="submit" value="Delete" class="btn btn-danger" />
                                <a href="@Url.Action("Index", "s_LabTest")" class="btn btn-secondary">Cancel</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- /Page Content -->
