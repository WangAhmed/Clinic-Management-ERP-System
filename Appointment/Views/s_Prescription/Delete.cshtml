@model Appointment.Models.s_Prescription

@{
    ViewBag.Title = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var appointments = ViewBag.Appointments as List<Appointment.Models.AppointmentViewModel>;
    var userType = Session["UserType"] as string;
    System.Diagnostics.Debug.WriteLine($"Current UserType: {userType}");

    // Determine the layout based on the user type
    if (userType == "Doctor")
    {
        Layout = "~/Views/Shared/_Layout_doctor.cshtml";
    }
    else if (userType == "Patient")
    {
        Layout = "~/Views/Shared/_Layout_patient.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
}


<!-- Breadcrumb -->
<div class="breadcrumb-bar">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-12 col-12">
                <nav aria-label="breadcrumb" class="page-breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="\Home\Index">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Delete Prescription</li>
                    </ol>
                </nav>
                <h2 class="breadcrumb-title">Delete Prescription</h2>
            </div>
        </div>
    </div>
</div>
<!-- /Breadcrumb -->
<!-- Page Content -->
<div class="content">
    <div class="container-fluid">

        <div class="row">
            <div class="col-md-5 col-lg-4 col-xl-3 theiaStickySidebar">
                @Html.Partial("_DoctorSidebar")
            </div>

            <div class="col-md-7 col-lg-8 col-xl-9">
                <div class="content container-fluid">
                    <div class="page-header">
                        <h3 class="page-title">Delete Prescription</h3>
                    </div>

                    <h4>Are you sure you want to delete this?</h4>
                    <div class="form-group">
                        <label class="control-label">Prescription ID</label>
                        <p>@Model.PrescriptionID</p>
                    </div>
                    <div class="form-group">
                        <label class="control-label">Appointment</label>
                        <p>@Model.s_Appointment.AppointmentDate</p>
                    </div>
                    <div class="form-group">
                        <label class="control-label">Medicine</label>
                        <p>@Model.m_medicines.name</p>
                    </div>
                    <div class="form-group">
                        <label class="control-label">Dosage</label>
                        <p>@Model.Dosage</p>
                    </div>
                    <div class="form-group">
                        <label class="control-label">Duration</label>
                        <p>@Model.Duration</p>
                    </div>
                    <div class="form-group">
                        <label class="control-label">Notes</label>
                        <p>@Model.Notes</p>
                    </div>

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.PrescriptionID)

                        <input type="submit" value="Delete" class="btn btn-danger" />
                        <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
                    }

                </div>
            </div>
        </div>

    </div>
</div>
<!-- /Page Content -->
