@model Appointment.Models.s_DoctorSchedule

@{
    ViewBag.Title = "Delete";
    var appointments = ViewBag.Appointments as List<Appointment.Models.AppointmentViewModel>;
    var userType = Session["UserType"] as string;
    System.Diagnostics.Debug.WriteLine($"Current UserType: {userType}");

    // Determine the layout based on the user type
    if (userType == "Doctor")
    {
        Layout = "~/Views/Shared/_Layout_doctor.cshtml";
    }
    else if (userType == "Patient")
    {
        Layout = "~/Views/Shared/_Layout_patient.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
}

<!-- Breadcrumb -->
<div class="breadcrumb-bar">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-12 col-12">
                <nav aria-label="breadcrumb" class="page-breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="\Home\Index">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Schedule Timings</li>
                    </ol>
                </nav>
                <h2 class="breadcrumb-title">Schedule Timings</h2>
            </div>
        </div>
    </div>
</div>
<!-- /Breadcrumb -->
<!-- Page Content -->
<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-5 col-lg-4 col-xl-3 theiaStickySidebar">
                <!-- Profile Sidebar -->
                @Html.Partial("_DoctorSidebar")
                <!-- /Profile Sidebar -->
            </div>

            <div class="col-md-7 col-lg-8 col-xl-9">
                <div class="card">
                    <div class="card-body">
                        <!-- Set the Schedule -->
                        <h3>Are you sure you want to delete this?</h3>
                        <div>
                            <h4>s_DoctorSchedule</h4>
                            <hr />
                            <dl class="dl-horizontal">
                                <dt>
                                    @Html.DisplayNameFor(model => model.AvailableDate)
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.AvailableDate)
                                </dd>

                                <dt>
                                    @Html.DisplayNameFor(model => model.StartTime)
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.StartTime)
                                </dd>

                                <dt>
                                    @Html.DisplayNameFor(model => model.EndTime)
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.EndTime)
                                </dd>

                                <dt>
                                    @Html.DisplayNameFor(model => model.s_Doctor.image)
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.s_Doctor.image)
                                </dd>

                            </dl>

                            @using (Html.BeginForm())
                            {
                                @Html.AntiForgeryToken()

                                <div class="form-actions no-color">
                                    <input type="submit" value="Delete" class="btn btn-danger" /> |
                                    @Html.ActionLink("Back to List", "Index")
                                </div>
                            }
                        </div>


                        <!-- /Profile Settings Form -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- /Page Content -->


