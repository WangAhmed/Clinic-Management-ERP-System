@model Appointment.Models.s_LabTest

@{
    ViewBag.Title = "Edit";
    var userType = Session["UserType"] as string;
    System.Diagnostics.Debug.WriteLine($"Current UserType: {userType}");

    // Determine the layout based on the user type
    if (userType == "Doctor")
    {
        Layout = "~/Views/Shared/_Layout_doctor.cshtml";
    }
    else if (userType == "Patient")
    {
        Layout = "~/Views/Shared/_Layout_patient.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
}

<<!-- Breadcrumb -->
<div class="breadcrumb-bar">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-12 col-12">
                <nav aria-label="breadcrumb" class="page-breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "s_LabTest")">Lab Tests</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Edit Lab Test</li>
                    </ol>
                </nav>
                <h2 class="breadcrumb-title">Edit Lab Test</h2>
            </div>
        </div>
    </div>
</div>
<!-- /Breadcrumb -->
<!-- Page Content -->
<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-5 col-lg-4 col-xl-3 theiaStickySidebar">
                @Html.Partial("_DoctorSidebar")
            </div>

            <div class="col-md-7 col-lg-8 col-xl-9">
                <div class="content container-fluid">
                    <div class="page-header">
                        <div class="row align-items-center">
                            <div class="col">
                                <h3 class="page-title">Edit Lab Test</h3>
                                <ul class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "s_LabTest")">Lab Tests</a></li>
                                    <li class="breadcrumb-item active">Edit Lab Test</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    @using (Html.BeginForm("Edit", "s_LabTest", FormMethod.Post, new { @class = "form-horizontal" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="card card-table">
                            <div class="card-body">
                                <div class="form-group">
                                    @Html.LabelFor(model => model.TestName, new { @class = "control-label" })
                                    @Html.TextBoxFor(model => model.TestName, new { @class = "form-control" })
                                    @Html.ValidationMessageFor(model => model.TestName, "", new { @class = "text-danger" })
                                </div>

                                <div class="form-group">
                                    @Html.LabelFor(model => model.PatientID, new { @class = "control-label" })
                                    @Html.DropDownListFor(model => model.PatientID, (SelectList)ViewBag.PatientID, "-- Select Patient --", new { @class = "form-control" })
                                    @Html.ValidationMessageFor(model => model.PatientID, "", new { @class = "text-danger" })
                                </div>

                                <div class="form-group">
                                    @Html.LabelFor(model => model.TestDate, new { @class = "control-label" })
                                    @Html.TextBoxFor(model => model.TestDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                    @Html.ValidationMessageFor(model => model.TestDate, "", new { @class = "text-danger" })
                                </div>

                                <div class="form-group">
                                    @Html.LabelFor(model => model.ChemicalsUsed, new { @class = "control-label" })
                                    @Html.TextAreaFor(model => model.ChemicalsUsed, new { @class = "form-control", rows = 3 })
                                    @Html.ValidationMessageFor(model => model.ChemicalsUsed, "", new { @class = "text-danger" })
                                </div>

                                <div class="form-group">
                                    @Html.LabelFor(model => model.LabProductsUsed, new { @class = "control-label" })
                                    @Html.TextAreaFor(model => model.LabProductsUsed, new { @class = "form-control", rows = 3 })
                                    @Html.ValidationMessageFor(model => model.LabProductsUsed, "", new { @class = "text-danger" })
                                </div>

                                <div class="form-group">
                                    @Html.LabelFor(model => model.Cost, new { @class = "control-label" })
                                    @Html.TextBoxFor(model => model.Cost, "{0:C}", new { @class = "form-control", type = "number", step = "0.01" })
                                    @Html.ValidationMessageFor(model => model.Cost, "", new { @class = "text-danger" })
                                </div>

                                <div class="form-group">
                                    @Html.LabelFor(model => model.Price, new { @class = "control-label" })
                                    @Html.TextBoxFor(model => model.Price, "{0:C}", new { @class = "form-control", type = "number", step = "0.01" })
                                    @Html.ValidationMessageFor(model => model.Price, "", new { @class = "text-danger" })
                                </div>

                                <div class="form-group">
                                    <input type="submit" value="Save Changes" class="btn btn-primary" />
                                    @Html.ActionLink("Cancel", "Index", "s_LabTest", new { id = Model.LabTestID }, new { @class = "btn btn-secondary" })
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<!-- /Page Content -->