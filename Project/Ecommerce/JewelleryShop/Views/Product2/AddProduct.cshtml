@model JewelleryShop.Models.Product

@{
    ViewBag.Title = "AddProduct";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@using (Html.BeginForm("AddProduct", "Product2", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <!-- Breadcrumbs Area Start -->
    <div class="breadcrumbs-area2">
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <h2>Add Products</h2>
                </div>
            </div>
        </div>
    </div>
    <!-- Breadcrumbs Area End -->
    <!-- My Account Area Start -->
    <div class="my-account-area section-padding">
        <div class="container">
            <div class="section-title2">
                <h4>@ViewBag.Msg</h4>
            </div>
            <div class="row">
                <div class="addresses-lists">
                    <div class="col-md-12">
                        <div class="panel-group" id="accordion" role="tablist" aria-multiselectable="true">
                            <div class="panel panel-default">
                                <div class="panel-heading" role="tab" id="headingOne">
                                    <h4 class="panel-title">
                                        <a role="button" data-toggle="collapse" data-parent="#accordion" href="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                            <i class="fa fa-building"></i>
                                            <span>Add Your Product Here</span>
                                        </a>
                                    </h4>
                                </div>

                                <div id="collapseOne" class="panel-collapse collapse in" role="tabpanel" aria-labelledby="headingOne">
                                    <div class="panel-body">
                                        <div class="coupon-info">



                                            <p class="required">*Required field</p>
                                            <form action="#">
                                                <p class="form-row">

                                                    @Html.LabelFor(model => model.ProductName, htmlAttributes: new { @class = "control-label col-md-2" })

                                                    @Html.EditorFor(model => model.ProductName, new { htmlAttributes = new { @class = "form-control" } })
                                                    @Html.ValidationMessageFor(model => model.ProductName, "", new { @class = "text-danger" })
                                                </p>

                                                <p class="form-row">

                                                    @Html.LabelFor(model => model.CategoryID, htmlAttributes: new { @class = "control-label col-md-2" })

                                                    @Html.DropDownListFor(model => model.CategoryID, new SelectList(@ViewBag.CatReclist, "CategoryID", "CategoryName"))

                                                </p>
                                                
                                                <p class="form-row">

                                                    @Html.LabelFor(model => model.UnitPrice, htmlAttributes: new { @class = "control-label col-md-2" })

                                                    @Html.EditorFor(model => model.UnitPrice, new { htmlAttributes = new { @class = "form-control" } })
                                                    @Html.ValidationMessageFor(model => model.UnitPrice, "", new { @class = "text-danger" })
                                                </p>
                                                <p class="form-row">

                                                    @Html.LabelFor(model => model.UnitsInStock, htmlAttributes: new { @class = "control-label col-md-2" })

                                                    @Html.EditorFor(model => model.UnitsInStock, new { htmlAttributes = new { @class = "form-control" } })
                                                    @Html.ValidationMessageFor(model => model.UnitsInStock, "", new { @class = "text-danger" })
                                                </p>
                                               



                                                <p class="form-row">

                                                    @Html.LabelFor(model => model.Discontinued, htmlAttributes: new { @class = "control-label col-md-2" })

                                                    <div class="checkbox">
                                                        @Html.EditorFor(model => model.Discontinued)
                                                        @Html.ValidationMessageFor(model => model.Discontinued, "", new { @class = "text-danger" })
                                                    </div>
                                                </p>

                                                <br />
                                                <br />


                                                <p class="form-row">

                                                    @Html.LabelFor(model => model.image, htmlAttributes: new { @class = "control-label col-md-2" })

                                                    <div class="col-md-10">
                                                        <input type="file" name="image" />
                                                    </div>
                                                </p>

                                                <div class="form-group">
                                                    <div class="col-md-10">
                                                        <input type="submit" value="Submit" class="btn btn-default" />
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="create-account-button pull-left">
                        <a href="/Home/Index" class="btn btn-default button button-small" title="Home">
                            <span>
                                <i class="fa fa-chevron-left"></i>
                                Home
                            </span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
<!-- My Account Area End -->
