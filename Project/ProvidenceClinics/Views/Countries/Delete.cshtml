@model ProvidenceClinics.Models.Country

@{
    ViewBag.Title = "Delete Countries";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="page-title">Delete Countries</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="\Countries\Index">Countries</a></li>
                        <li class="breadcrumb-item active">Delete Countries</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <div class="card">
                    <div class="card-body">

                        <h3>Are you sure you want to delete this?</h3>
                        <div>
                            <hr />
                            <dl class="dl-horizontal">
                                <dt>
                                    @Html.DisplayNameFor(model => model.CountryName)
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.CountryName)
                                </dd>

                            </dl>

                            @using (Html.BeginForm())
                            {
                                @Html.AntiForgeryToken()

                                <div class="form-actions no-color">
                                    <input type="submit" value="Delete" class="btn btn-success" /> |
                                    @Html.ActionLink("Cancel", "Index")
                                </div>
                            }
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

