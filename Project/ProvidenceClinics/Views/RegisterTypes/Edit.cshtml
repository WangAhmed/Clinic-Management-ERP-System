@model ProvidenceClinics.Models.RegisterType

@{
    ViewBag.Title = "Edit Reg Type";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="page-title">Edit Reg Type</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="\RegisterTypes/Index">Reg Type</a></li>
                        <li class="breadcrumb-item active">Edit Reg Type</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <div class="card">
                    <div class="card-body">
                        <form>
                            @using (Html.BeginForm())
                            {
                                @Html.AntiForgeryToken()

                                <div class="form-horizontal">
                                    <hr />
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    @Html.HiddenFor(model => model.RegisterTypeID)

                                    <div class="form-group">
                                        <label class="control-label col-12"> Register Type </label>
                                        <div class="col-md-8">
                                            @Html.EditorFor(model => model.TypeName, new { htmlAttributes = new { @class = "form-control" } })
                                            @Html.ValidationMessageFor(model => model.TypeName, "", new { @class = "text-danger" })
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <div class="col-md-offset-2 col-md-8">
                                            <input type="submit" value="Save" class="btn btn-success" />
                                        </div>
                                    </div>
                                </div>
                            }
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>





