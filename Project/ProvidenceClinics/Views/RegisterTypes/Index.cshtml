@model IEnumerable<ProvidenceClinics.Models.RegisterType>

@{
    ViewBag.Title = "Index Regtype";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="page-title">Registeration Type</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="\Home\Index">Dashboard</a></li>
                        <li class="breadcrumb-item active">Registeration</li>
                    </ul>
                </div>
                <div class="col-auto text-right float-right ml-auto">
                    <a href="\RegisterTypes\Create" class="btn btn-primary">
                        Add New RegType 
                        <i class="fas fa-plus"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <div class="card card-table">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover table-center mb-0 datatable">
                                <thead>
                                    <tr>

                                        <th>
                                            Registeration Id
                                        </th>
                                        <th>
                                            Registeration Type
                                        </th>

                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.RegisterTypeID)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.TypeName)
                                            </td>
                                            <td>
                                                <button>  @Html.ActionLink("Edit", "Edit", new { id = item.RegisterTypeID })</button> |
                                                <button> @Html.ActionLink("Delete", "Delete", new { id = item.RegisterTypeID })</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


