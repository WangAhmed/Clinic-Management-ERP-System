@model IEnumerable<ProvidenceClinics.Models.Register>

@{
    ViewBag.Title = "Index Registeration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="page-title">Registeration</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="\Home\Index"> Dashboard</a></li>
                        <li class="breadcrumb-item active">Registeration</li>
                    </ul>
                </div>
                <div class="col-auto text-right float-right ml-auto">
                    <a href="\Registers\Create" class="btn btn-primary">Add New Registeration <i class="fas fa-plus"></i></a>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <div class="card card-table">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover table-center mb-0 datatable">
                                <thead>
                                    <tr>
                                        <th>
                                            Username
                                        </th>
                                        <th>
                                            Image
                                        </th>
                                        <th>
                                           Email
                                        </th>
                                        <th>
                                           City
                                        </th>
                                        <th>
                                           Country
                                        </th>
                                        <th>
                                            Registeration Type
                                        </th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.Username)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.image)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.Email)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.City.CityName)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.Country.CountryName)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.RegisterType.TypeName)
                                            </td>
                                            <td>
                                                <button>@Html.ActionLink("Edit", "Edit", new { id = item.RegisterID }) </button> | 
                                                <button>@Html.ActionLink("Details", "Details", new { id = item.RegisterID }) </button> | 
                                                <button>@Html.ActionLink("Delete", "Delete", new { id = item.RegisterID }) </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer>
        <p>Copyright © 2024 ProvidenceClinic.</p>
    </footer>
</div>


