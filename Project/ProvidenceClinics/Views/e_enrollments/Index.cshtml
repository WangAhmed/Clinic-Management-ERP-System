@model IEnumerable<ProvidenceClinics.Models.e_enrollments>

@{
    ViewBag.Title = "Index Enrollment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="page-title">Enrollment</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="\Home\Index">Dashboard</a></li>
                        <li class="breadcrumb-item active">Education</li>
                    </ul>
                </div>
                <div class="col-auto text-right float-right ml-auto">
                    <a href="\e_enrollments\Create" class="btn btn-primary"> Add New Enrollment 
                        <i class="fas fa-plus"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <div class="card card-table">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover table-center mb-0 datatable">
                                <thead>
                                    <tr class="align-self-center">
                                        <th>
                                            RegID
                                        </th>
                                        <th>
                                            Student
                                        </th>
                                        <th>
                                            Teacher
                                        </th>
                                        <th>
                                            Subject
                                        </th>
                                        <th>
                                            Lec/Sem/Prac
                                        </th>
                                        <th>
                                            Enrollment Date
                                        </th>
                                        <th>
                                            Fees
                                        </th>
                                        <th>
                                            Class Name
                                        </th>
                                        <th>
                                            Action 
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>

                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.regid)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.e_students.name)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.e_staff.name)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.e_subject.name)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.e_lsp.name)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.enrollment_date)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.fee)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.e_class.name)
                                            </td>
                                            <td>
                                                <button> @Html.ActionLink("Edit", "Edit", new { id = item.enid })</button> |
                                                <button> @Html.ActionLink("Details", "Details", new { id = item.enid }) </button> |
                                                <button> @Html.ActionLink("Delete", "Delete", new { id = item.enid })</button>
                                            </td>
                                        </tr>
                                    }

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>