@model ProvidenceClinics.Models.e_lsp

@{
    ViewBag.Title = "Delete Lec/Sem/Prac";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row">
                <div class="col-sm-12">
                    <h3 class="page-title">lsp Details</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="\e_lsp\Index">Lec/Sem/Prac </a></li> |
                        <li class="breadcrumb-item active">Delete Lec/Sem/Prac</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="about-info">

                            <h3>Are you sure you want to delete this?</h3>

                            <div>
                                <hr />
                                <dl class="dl-horizontal">
                                    <dt>
                                        Lec/Sem/Prac Name
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.name)
                                    </dd>

                                    <dt>
                                        Description
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.description)
                                    </dd>

                                    <dt>
                                        Lec/Sem/Prac Type
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.e_lsp_type.type)
                                    </dd>

                                </dl>

                                @using (Html.BeginForm())
                                {
                                    @Html.AntiForgeryToken()

                                    <div class="form-actions no-color">
                                        <input type="submit" value="Delete" class="btn btn-success" /> |
                                        @Html.ActionLink("Cancel", "Index")
                                    </div>
                                }
                            </div>




                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

</div>
