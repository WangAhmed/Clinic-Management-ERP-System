@model ProvidenceClinics.Models.m_customers

@{
    ViewBag.Title = "Customer Detail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row">
                <div class="col-sm-12">
                    <h3 class="page-title">Customer Details</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/m_customers/Index">Customers</a></li>
                        <li class="breadcrumb-item active">Customers Details</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="about-info">
                            <dl class="dl-horizontal">
                               
                                <dt>
                                    RegID
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.Register.RegisterID)
                                </dd>
                                <dt>
                                   Image
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.image)
                                </dd>

                                <dt>
                                    Customer Name
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.name)
                                </dd>

                                <dt>
                                    Address
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.address)
                                </dd>

                                <dt>
                                    Phone
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.phone)
                                </dd>


                            </dl>

                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </div>

    <footer>
        <p>Copyright © 2024 ProvidenceClinic.</p>
    </footer>

</div>


