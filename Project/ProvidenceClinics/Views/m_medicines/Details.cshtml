@model ProvidenceClinics.Models.m_medicines

@{
    ViewBag.Title = "Medicine Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row">
                <div class="col-sm-12">
                    <h3 class="page-title">Medicine Details</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="\m_medicines\Index">medicines</a></li>
                        <li class="breadcrumb-item active">Medicine Details</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="about-info">
                            <dl class="dl-horizontal">
                                <dt>
                                    Medicines Name
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.name)
                                </dd>

                                <dt>
                                    Image
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.image)
                                </dd>

                                <dt>
                                    Price
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.price)
                                </dd>

                                <dt>
                                    QTY
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.quantity_in_stock)
                                </dd>

                                <dt>
                                    Med Category
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.m_categories.name)
                                </dd>

                                <dt>
                                    Med Supplier
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.m_suppliers.name)
                                </dd>

                                <dt>
                                    Med Type
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.m_types.type)
                                </dd>

                            </dl>
                        </div>
                    </div>
                </div>
             
            </div>
        </div>
    </div>

    <footer>
        <p>Copyright © 2024 ProvidenceClinic.</p>
    </footer>

</div>
