@model IEnumerable<ProvidenceClinics.Models.m_medicines>

@{
    ViewBag.Title = "Index Medicine";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="page-title">Medicines</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="\Home\Index">Dashboard</a></li>
                        <li class="breadcrumb-item active">Medicine</li>
                    </ul>
                </div>
                <div class="col-auto text-right float-right ml-auto">
                   
                    <a href="\m_medicines\Create" class="btn btn-primary"> Add New Medicines 



                        <i class="fas fa-plus"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <div class="card card-table">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover table-center mb-0 datatable">
                                <thead>
                                    <tr>
                                        <th>
                                            Med Name
                                        </th>
                                        <th>
                                            Image
                                        </th>
                                        <th>
                                            Price
                                        </th>
                                        <th>
                                            QTY 
                                        </th>
                                        <th>
                                            Med Category
                                        </th>
                                        <th>
                                            Med Supplier
                                        </th>
                                        <th>
                                            Med Type
                                        </th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>

                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.name)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.image)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.price)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.quantity_in_stock)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.m_categories.name)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.m_suppliers.name)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.m_types.type)
                                            </td>
                                            <td>
                                                <button> @Html.ActionLink("Edit", "Edit", new { id = item.medid }) </button> |
                                                <button> @Html.ActionLink("Details", "Details", new { id = item.medid })</button> |
                                                <button> @Html.ActionLink("Delete", "Delete", new { id = item.medid })</button>
                                            </td>
                                        </tr>
                                    }

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer>
        <p>Copyright © 2024 ProvidenceClinic.</p>
    </footer>
</div>
