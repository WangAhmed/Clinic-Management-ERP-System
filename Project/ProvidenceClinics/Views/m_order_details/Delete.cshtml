@model ProvidenceClinics.Models.m_order_details

@{
    ViewBag.Title = "Delete Med Order Detail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row">
                <div class="col-sm-12">
                    <h3 class="page-title">Delete Med Order Delete</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/m_order_details/Index">Order Details</a></li>
                        <li class="breadcrumb-item active">Delete Med Order Delete</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="about-info">
                            <h4>About Me</h4>
                            <h3>Are you sure you want to delete this?</h3>
                            <div>
                                <hr />
                                <dl class="dl-horizontal">
                                    <dt>
                                        Medicine
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.m_medicines.name)
                                    </dd>
                                    
                                    <dt>
                                        Qty
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.quantity)
                                    </dd>

                                    <dt>
                                        Unit Prize
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.unit_price)
                                    </dd>

                                    <dt>
                                        OrderType
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.m_orders.ordertype)
                                    </dd>

                                </dl>

                                @using (Html.BeginForm())
                                {
                                    @Html.AntiForgeryToken()

                                    <div class="form-actions no-color">
                                        <input type="submit" value="Delete" class="btn btn-success" /> |
                                        @Html.ActionLink("Cancel", "Index")
                                    </div>
                                }
                            </div>

                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </div>

    <footer>
        <p>Copyright © 2024 ProvidenceClinic.</p>
    </footer>

</div>
