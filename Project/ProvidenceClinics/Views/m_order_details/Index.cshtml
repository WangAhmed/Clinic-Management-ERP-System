@model IEnumerable<ProvidenceClinics.Models.m_order_details>

@{
    ViewBag.Title = "Index Med Order";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="page-title">Order Details</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="\Home\Index">Dashboard</a></li>
                        <li class="breadcrumb-item active">Medicine</li>
                    </ul>
                </div>
                <div class="col-auto text-right float-right ml-auto">
                     
                    <a href="/m_order_details/Create" class="btn btn-primary">Add New Med Order<i class="fas fa-plus"></i></a>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <div class="card card-table">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover table-center mb-0 datatable">
                                <thead>
                                    <tr>
                                        <th>
                                            Medicine
                                        </th>
                                        <th>
                                            Quantity
                                        </th>
                                        <th>
                                            Unit Price
                                        </th>
                                        <th>
                                            Order Type
                                        </th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.m_medicines.name)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.quantity)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.unit_price)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.m_orders.ordertype)
                                            </td>
                                            <td>
                                                <button>@Html.ActionLink("Edit", "Edit", new { id = item.odid }) </button> |
                                                <button>@Html.ActionLink("Details", "Details", new { id = item.odid }) </button> |
                                                <button>@Html.ActionLink("Delete", "Delete", new { id = item.odid }) </button>
                                            </td>
                                        </tr>
                                    }

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer>
        <p>Copyright © 2024 ProvidenceClinic.</p>
    </footer>
</div>

