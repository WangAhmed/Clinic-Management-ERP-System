@model ProvidenceClinics.Models.m_orders

@{
    ViewBag.Title = "Details Med Order";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row">
                <div class="col-sm-12">
                    <h3 class="page-title">Med Orders Detail</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/m_orders/Index">Med Orders</a></li>
                        <li class="breadcrumb-item active">Med Orders Details</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="about-info">
                            <h4>About Me</h4>
                                <dl class="dl-horizontal">
                                    <dt>
                                        Customer
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.m_customers.cusid)
                                    </dd>
                                    <dt>
                                        Customer name
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.m_customers.name)
                                    </dd>
                                    <dt>
                                        Order Date
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.order_date)
                                    </dd>

                                    <dt>
                                        Order Type
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.ordertype)
                                    </dd>
                                </dl>
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </div>

    <footer>
        <p>Copyright © 2024 ProvidenceClinic.</p>
    </footer>

</div>
