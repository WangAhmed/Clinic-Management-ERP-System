@model IEnumerable<ProvidenceClinics.Models.m_orders>

@{ 
    ViewBag.Title = "Index Med Order ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="page-title">Med Orders</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="\Home\Index">Dashboard</a></li>
                        <li class="breadcrumb-item active">MedIcine</li>
                    </ul>
                </div>
                <div class="col-auto text-right float-right ml-auto">
                     
                    <a href="/m_orders/Create" class="btn btn-primary">Add New Med Order <i class="fas fa-plus"></i></a>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <div class="card card-table">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover table-center mb-0 datatable">
                                <thead>
                                    <tr>
                                        <th>
                                            CustomerID
                                        </th>
                                        <th>
                                            Customer Name
                                        </th>
                                        <th>
                                            Order Date
                                        </th>
                                        <th>
                                            Order Type
                                        </th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.m_customers.cusid)
                                            </td>
                                            <td>
                                            @Html.DisplayFor(modelItem => item.m_customers.name)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.order_date)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.ordertype)
                                            </td>
                                            <td>
                                                <button>@Html.ActionLink("Edit", "Edit", new { id = item.oid }) </button> |
                                                <button> @Html.ActionLink("Details", "Details", new { id = item.oid }) </button> |
                                                <button>  @Html.ActionLink("Delete", "Delete", new { id = item.oid })</button>
                                            </td>
                                        </tr>
                                    }
                                 </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer>
        <p>Copyright © 2024 ProvidenceClinic.</p>
    </footer>
</div>