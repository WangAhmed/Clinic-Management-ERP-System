@model ProvidenceClinics.Models.m_types

@{
    ViewBag.Title = "Edit Medicine Types";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="page-title">Edit Medicine Types</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/m_types/Index">types</a>Medicine Type</li>
                        <li class="breadcrumb-item active">Edit Medicine Types</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <div class="card">
                    <div class="card-body">
                        @using (Html.BeginForm())
                        {
                            @Html.AntiForgeryToken()

                            <div class="form-horizontal">
                                <h4>m_types</h4>
                                <hr />
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @Html.HiddenFor(model => model.medtypeid)

                                <div class="form-group">
                                    <label class="control-label col-12"> Medicine Type </label>
                                    <div class="col-md-8">
                                        @Html.EditorFor(model => model.type, new { htmlAttributes = new { @class = "form-control" } })
                                        @Html.ValidationMessageFor(model => model.type, "", new { @class = "text-danger" })
                                    </div>
                                </div>

                                <div class="form-group">
                                    <div class="col-md-offset-2 col-md-8">
                                        <input type="submit" value="Save" class="btn btn-success" />
                                    </div>
                                </div>
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

