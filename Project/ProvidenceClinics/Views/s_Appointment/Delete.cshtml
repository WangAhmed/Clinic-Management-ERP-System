@model ProvidenceClinics.Models.s_Appointment

@{
    ViewBag.Title = "Delete Appointment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row">
                <div class="col-sm-12">
                    <h3 class="page-title">Appointment Delete</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/s_Appointment/Index">Appointment</a></li>
                        <li class="breadcrumb-item active">Appointment Delete</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="about-info">
                            <h3>Are you sure you want to delete this?</h3>
                            <div>
                                <hr />
                                <dl class="dl-horizontal">
                                    <dt>
                                        Doctor Name
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.s_Doctor.FirstName)
                                    </dd>

                                    <dt>
                                        Patient Name
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.s_Patient.FirstName)
                                    </dd>

                                    <dt>
                                        Appointment Date
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.AppointmentDate)
                                    </dd>

                                    <dt>
                                        Appointment Time
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.AppointmentTime)
                                    </dd>

                                    <dt>
                                        Fees
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.fee)
                                    </dd>


                                    <dt>
                                        Status
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.s_Status.StatusName)
                                    </dd>

                                </dl>

                                @using (Html.BeginForm())
                                {
                                    @Html.AntiForgeryToken()

                                    <div class="form-actions no-color">
                                        <input type="submit" value="Delete" class="btn btn-success" /> |
                                        @Html.ActionLink("Cancel", "Index")
                                    </div>
                                }
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

</div>

