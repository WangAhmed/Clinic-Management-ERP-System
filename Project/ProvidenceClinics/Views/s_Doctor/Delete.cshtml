@model ProvidenceClinics.Models.s_Doctor

@{
    ViewBag.Title = "Delete Doctor";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row">
                <div class="col-sm-12">
                    <h3 class="page-title">Delete Doctor</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/s_Doctor/Index">Doctor</a></li>
                        <li class="breadcrumb-item active">Delete Doctor</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="about-info">
                            <h3>Are you sure you want to delete this?</h3>
                            <div>
                                <hr />
                                <dl class="dl-horizontal">
                                    <dt>
                                        Regid
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.Register.RegisterID)
                                    </dd>

                                    <dt>
                                        Image
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.image)
                                    </dd>

                                    <dt>
                                        First Name
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.FirstName)
                                    </dd>

                                    <dt>
                                        LastName
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.LastName)
                                    </dd>

                                    <dt>
                                        Contact
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.ContactNumber)
                                    </dd>

                                    <dt>
                                        Email
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.Email)
                                    </dd>


                                    <dt>
                                        Specialty
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.s_Specialist.SpecialistName)
                                    </dd>

                                </dl>

                                @using (Html.BeginForm())
                                {
                                    @Html.AntiForgeryToken()

                                    <div class="form-actions no-color">
                                        <input type="submit" value="Delete" class="btn btn-success" /> |
                                        @Html.ActionLink("Cancel", "Index")
                                    </div>
                                }
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

</div>

