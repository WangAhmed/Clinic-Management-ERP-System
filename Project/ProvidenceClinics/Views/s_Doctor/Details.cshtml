@model ProvidenceClinics.Models.s_Doctor

@{
    ViewBag.Title = "Doctor Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row">
                <div class="col-sm-12">
                    <h3 class="page-title">Doctor Details</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/s_Doctor/Index">Doctor</a></li>
                        <li class="breadcrumb-item active"> Doctor Details</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="about-info">
                            <div>
                                <hr />
                                <dl class="dl-horizontal">
                                    <dt>
                                        Regid
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.Register.RegisterID)
                                    </dd>

                                    <dt>
                                        Image
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.image)
                                    </dd>

                                    <dt>
                                        First Name
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.FirstName)
                                    </dd>

                                    <dt>
                                        LastName
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.LastName)
                                    </dd>

                                    <dt>
                                        Contact
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.ContactNumber)
                                    </dd>

                                    <dt>
                                        Email
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.Email)
                                    </dd>


                                    <dt>
                                        Specialty
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.s_Specialist.SpecialistName)
                                    </dd>

                                </dl>
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

</div>

