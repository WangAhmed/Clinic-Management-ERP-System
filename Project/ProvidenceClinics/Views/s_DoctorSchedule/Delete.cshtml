@model ProvidenceClinics.Models.s_DoctorSchedule


    ViewBag.Title = "Delete Doctor Schedule";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row">
                <div class="col-sm-12">
                    <h3 class="page-title">Delete Doctor Schedule</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/s_DoctorSchedule">Doctor Schedule</a></li>
                        <li class="breadcrumb-item active">Delete Doctor Schedule</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="about-info">
                            <h4>Are you sure you want to delete this?</h4>
                            <div>
                                <dl class="dl-horizontal">
                                    <dt>
                                        DoctorID
                                    </dt>
                                    <dd>
                                        @Html.DisplayFor(model => model.DoctorID)
                                    </dd>
                                    <dt>
                                        Available Date
                                    </dt>
                                    <dd>
                                        @Html.DisplayFor(model => model.AvailableDate)
                                    </dd>
                                    <dt>
                                        Start Time
                                    </dt>
                                    <dd>
                                        @Html.DisplayFor(model => model.StartTime)
                                    </dd>
                                    <dt>
                                        End Time
                                    </dt>
                                    <dd>
                                        @Html.DisplayFor(model => model.EndTime)
                                    </dd>
                                    <dt>
                                        Doctor Name
                                    </dt>
                                    <dd>
                                        @Html.DisplayFor(model => model.s_Doctor.FirstName)
                                    </dd>
                                </dl>
                            </div>


                            @using (Html.BeginForm())
                            {
                                @Html.AntiForgeryToken()
                                @Html.HiddenFor(model => model.DoctorID)
                                @Html.HiddenFor(model => model.AvailableDate)
                                <div class="form-group">
                                    <input type="submit" value="Delete" class="btn btn-danger" />
                                    @Html.ActionLink("Cancel", "Index")
                                </div>
                            }

                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

</div>
