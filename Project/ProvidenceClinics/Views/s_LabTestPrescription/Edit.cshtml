@model ProvidenceClinics.Models.s_LabTestPrescription

@{
    ViewBag.Title = "Edit LabTestPrescription";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="page-title">Edit  LabTestPrescription</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/s_LabTestPrescription/Index">LabTestPrescription</a></li>
                        <li class="breadcrumb-item active">Edit  LabTestPrescription</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <div class="card">
                    <div class="card-body">
                        @using (Html.BeginForm())
                        {
                            @Html.AntiForgeryToken()

                            <div class="form-horizontal">
                                <hr />
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @Html.HiddenFor(model => model.LabTestPrescriptionID)

                                <div class="form-group">
                                    @Html.LabelFor(model => model.LabTestID, "LabTestID", htmlAttributes: new { @class = "control-label  col-12" })
                                    <div class="col-md-8">
                                        @Html.DropDownList("LabTestID", null, htmlAttributes: new { @class = "form-control" })
                                        @Html.ValidationMessageFor(model => model.LabTestID, "", new { @class = "text-danger" })
                                    </div>
                                </div>

                                <div class="form-group">
                                    @Html.LabelFor(model => model.PrescriptionID, "PrescriptionID", htmlAttributes: new { @class = "control-label  col-12" })
                                    <div class="col-md-8">
                                        @Html.DropDownList("PrescriptionID", null, htmlAttributes: new { @class = "form-control" })
                                        @Html.ValidationMessageFor(model => model.PrescriptionID, "", new { @class = "text-danger" })
                                    </div>
                                </div>

                                <div class="form-group">
                                    <div class="col-md-offset-2 col-md-8">
                                        <input type="submit" value="Save" class="btn btn-success" />
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
