@model ProvidenceClinics.Models.s_Product

@{
    ViewBag.Title = "Product Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row">
                <div class="col-sm-12">
                    <h3 class="page-title">Details Product</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/s_Product/Index">Product</a></li>
                        <li class="breadcrumb-item active">Details Product</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="about-info">
                            <dl class="dl-horizontal">
                                <dt>
                                    @Html.DisplayNameFor(model => model.ProductName)
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.ProductName)
                                </dd>

                                <dt>
                                    @Html.DisplayNameFor(model => model.image)
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.image)
                                </dd>

                                <dt>
                                    @Html.DisplayNameFor(model => model.Description)
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.Description)
                                </dd>

                                <dt>
                                    @Html.DisplayNameFor(model => model.Price)
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.Price)
                                </dd>

                                <dt>
                                    @Html.DisplayNameFor(model => model.QuantityInStock)
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.QuantityInStock)
                                </dd>

                                <dt>
                                    @Html.DisplayNameFor(model => model.s_Category.CategoryName)
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.s_Category.CategoryName)
                                </dd>

                                <dt>
                                    @Html.DisplayNameFor(model => model.s_Supplier.SupplierName)
                                </dt>

                                <dd>
                                    @Html.DisplayFor(model => model.s_Supplier.SupplierName)
                                </dd>

                            </dl>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <footer>
        <p>Copyright © 2024 ProvidenceClinic.</p>
    </footer>

</div>
