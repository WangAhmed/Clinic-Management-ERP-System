@model IEnumerable<ProvidenceClinics.Models.s_Specialist>

@{
    ViewBag.Title = "Index Specialist";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="page-title">Specialist</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="\Home\INdex">Dashboard</a></li>
                        <li class="breadcrumb-item active">Appointment</li>
                    </ul>
                </div>
                <div class="col-auto text-right float-right ml-auto">
                    <a href="" class="btn btn-primary">Add New Specialist <i class="fas fa-plus"></i></a>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <div class="card card-table">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover table-center mb-0 datatable">
                                <thead>
                                    <tr>
                                        <th>
                                            @Html.DisplayNameFor(model => model.SpecialistName)
                                        </th>
                                        <th>Action</th>
                                    </tr>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.SpecialistName)
                                            </td>
                                            <td>
                                                <button>@Html.ActionLink("Edit", "Edit", new { id = item.SpecialistID })  </button> |
                                                <button>@Html.ActionLink("Delete", "Delete", new { id = item.SpecialistID }) </button>
                                            </td>
                                        </tr>
                                    }
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer>
        <p>Copyright © 2024 ProvidenceClinic.</p>
    </footer>
</div>



<button> </button> |
<button> </button> |
<button> </button>
