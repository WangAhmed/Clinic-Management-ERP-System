@model ProvidenceClinics.Models.s_Transaction

@{
    ViewBag.Title = "Delete Transaction";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="content container-fluid">
        <div class="page-header">
            <div class="row">
                <div class="col-sm-12">
                    <h3 class="page-title">Delete Transaction</h3>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/s_Transaction/Index">Transaction</a></li>
                        <li class="breadcrumb-item active">Delete Transaction</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="about-info">
                            <h3>Are you sure you want to delete this?</h3>
                            <div>
                                <hr />
                                <dl class="dl-horizontal">
                                    <dt>
                                        @Html.DisplayNameFor(model => model.ProductID)
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.ProductID)
                                    </dd>

                                    <dt>
                                        @Html.DisplayNameFor(model => model.TransactionDate)
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.TransactionDate)
                                    </dd>

                                    <dt>
                                        @Html.DisplayNameFor(model => model.Quantity)
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.Quantity)
                                    </dd>

                                    <dt>
                                        @Html.DisplayNameFor(model => model.PurchasePrice)
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.PurchasePrice)
                                    </dd>

                                    <dt>
                                        @Html.DisplayNameFor(model => model.SellingPrice)
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.SellingPrice)
                                    </dd>

                                    <dt>
                                        @Html.DisplayNameFor(model => model.s_Order.Status)
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.s_Order.Status)
                                    </dd>

                                    <dt>
                                        @Html.DisplayNameFor(model => model.s_Supplier.SupplierName)
                                    </dt>

                                    <dd>
                                        @Html.DisplayFor(model => model.s_Supplier.SupplierName)
                                    </dd>

                                </dl>

                                @using (Html.BeginForm())
                                {
                                    @Html.AntiForgeryToken()

                                    <div class="form-actions no-color">
                                        <input type="submit" value="Delete" class="btn btn-success" /> |
                                        @Html.ActionLink("Cancel", "Index")
                                    </div>
                                }
                            </div>

                        </div>
                    </div>
                </div>
               
            </div>
        </div>
    </div>

    <footer>
        <p>Copyright © 2024 ProvidenceClinic.</p>
    </footer>

</div>
